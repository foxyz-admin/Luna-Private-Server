{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/api/register", "dest": "/api/register.js" },
    { "src": "/api/login", "dest": "/api/login.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
